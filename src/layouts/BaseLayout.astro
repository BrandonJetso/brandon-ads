---
interface Props { title: string; description?: string; }
const { title, description = 'Curated HK retail promotions, scored and published automatically.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | BrandON Ads</title>
    <meta name="description" content={description} />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --brand: #E84040; --brand-dark: #C42E2E;
        --bg: #F4F5F7; --card: #FFFFFF;
        --text: #111827; --muted: #6B7280; --border: #E5E7EB;
        --radius: 12px; --shadow: 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.06);
      }
      body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; flex-direction: column; }
      a { color: inherit; text-decoration: none; }
      img { display: block; }
      .site-header { background: #fff; border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; }
      .site-header .inner { max-width: 1100px; margin: 0 auto; padding: 0 1.25rem; height: 60px; display: flex; align-items: center; justify-content: space-between; }
      .site-logo { font-weight: 700; font-size: 1.15rem; }
      .site-logo .dot { color: var(--brand); }
      .site-nav a { font-size: .875rem; font-weight: 500; color: var(--muted); margin-left: 1.5rem; transition: color .15s; }
      .site-nav a:hover { color: var(--text); }
      .site-footer { background: #fff; border-top: 1px solid var(--border); padding: 1.5rem 1.25rem; text-align: center; font-size: .8rem; color: var(--muted); }
      .site-footer a { color: var(--muted); margin: 0 .5rem; }
      .site-footer a:hover { color: var(--brand); }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a href="/" class="site-logo">BrandON<span class="dot">.</span>ads</a>
        <nav class="site-nav">
          <a href="/">Home</a>
          <a href="/ads.json" target="_blank">Feed</a>
          <a href="/sitemap-index.xml" target="_blank">Sitemap</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <a href="/">BrandON Ads</a> ·
      <a href="https://thebrandonapp.com" target="_blank">BrandON App</a> ·
      <a href="/llms.txt">llms.txt</a><br />
      © {new Date().getFullYear()} BrandON. Curated HK promotions.
    </footer>
  </body>
</html>
