---
import BaseLayout from '../layouts/BaseLayout.astro';
import adsData from '../data/ads.json';
const ads = [...adsData].sort((a, b) => Number(b.score) - Number(a.score));
---
<BaseLayout title="Latest HK Promotions">
  <div class="banner">
    <div class="pill">Live Feed</div>
    <h1>Hong Kong's Best Promotions</h1>
    <p>{ads.length} curated ads · Updated automatically</p>
  </div>
  <main>
    <div class="grid">
      {ads.map(ad => {
        const score = Number(ad.score);
        const sc = score >= 8 ? 'high' : score >= 5 ? 'mid' : 'low';
        const brand = ad.brand || 'HK Brand';
        const hasMedia = ad.image_url || ad.video_url;
        return (
          <a href={`/en/${ad.ad_id}`} class="card">
            {hasMedia && (
              <div class="card-media">
                {ad.video_url
                  ? <video src={ad.video_url} muted playsinline loop class="media-asset" />
                  : <img src={ad.image_url} alt={ad.title || brand} class="media-asset" />}
              </div>
            )}
            <div class="card-body">
              <div class="card-header">
                {ad.logo
                  ? <img src={ad.logo} alt={brand} class="logo" width="40" height="40" />
                  : <div class="logo-placeholder">{brand[0]}</div>}
                <div class="brand-info">
                  <div class="brand-name">{brand}</div>
                  {ad.valid_until && <div class="valid">Until {ad.valid_until}</div>}
                </div>
                <span class={`badge ${sc}`}>{ad.score}</span>
              </div>
              {ad.category && <span class="category-tag">{ad.category}</span>}
              <p class="ad-title">{ad.title}</p>
              <p class="ad-offer">{ad.offer}</p>
            </div>
          </a>
        );
      })}
    </div>
  </main>
</BaseLayout>

<style>
  .banner { background: linear-gradient(135deg,#1A1A2E,#16213E); color:#fff; padding: 3rem 1.25rem; text-align:center; }
  .pill { display:inline-block; background:var(--brand); color:#fff; font-size:.75rem; font-weight:600; padding:.25rem .75rem; border-radius:999px; margin-bottom:1rem; text-transform:uppercase; letter-spacing:.05em; }
  .banner h1 { font-size: clamp(1.5rem,4vw,2.25rem); font-weight:700; margin-bottom:.5rem; }
  .banner p { color:rgba(255,255,255,.65); }
  main { max-width:1100px; margin:0 auto; padding:2rem 1.25rem; flex:1; }
  .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1.25rem; }
  .card { background:var(--card); border:1px solid var(--border); border-radius:var(--radius); box-shadow:var(--shadow); display:flex; flex-direction:column; overflow:hidden; transition:transform .15s,box-shadow .15s; text-decoration:none; color:inherit; }
  .card:hover { transform:translateY(-2px); box-shadow:0 4px 24px rgba(0,0,0,.12); }
  .card-media { width:100%; aspect-ratio:16/9; overflow:hidden; background:#f3f4f6; }
  .media-asset { width:100%; height:100%; object-fit:cover; display:block; }
  .card-body { padding:1.25rem; display:flex; flex-direction:column; gap:.6rem; flex:1; }
  .card-header { display:flex; align-items:center; gap:.75rem; }
  .logo { width:40px; height:40px; border-radius:8px; object-fit:cover; flex-shrink:0; }
  .logo-placeholder { width:40px; height:40px; border-radius:8px; background:var(--brand); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:1.1rem; flex-shrink:0; }
  .brand-info { flex:1; min-width:0; }
  .brand-name { font-weight:600; font-size:.9rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .valid { font-size:.75rem; color:var(--muted); }
  .badge { font-size:.8rem; font-weight:700; padding:.25rem .6rem; border-radius:999px; flex-shrink:0; }
  .badge.high { background:#DCFCE7; color:#166534; }
  .badge.mid  { background:#FEF9C3; color:#854D0E; }
  .badge.low  { background:#FEE2E2; color:#991B1B; }
  .category-tag { display:inline-block; background:#EEF2FF; color:#4338CA; font-size:.7rem; font-weight:600; padding:.2rem .6rem; border-radius:999px; text-transform:uppercase; letter-spacing:.04em; width:fit-content; }
  .ad-title { font-size:.9rem; font-weight:500; line-height:1.4; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
  .ad-offer { font-size:.85rem; color:var(--muted); line-height:1.4; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
</style>
